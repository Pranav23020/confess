# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Atlas (Cloud)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/confessions?retryWrites=true&w=majority

# Redis (Upstash - from your .env)
REDIS_URL=rediss://default:AVbUAAIncDI2OTIzOTIxZWVmMDQ0NjE5OTEwMDkyYmIwN2ZjZWU5OXAyMjIyMjg@positive-chimp-22228.upstash.io:6379

# Security (Change these to strong random strings!)
DEVICE_HASH_SECRET=your-production-device-hash-secret-change-this
SESSION_SECRET=your-production-session-secret-change-this
JWT_SECRET=your-production-jwt-secret-change-this

# Rate Limiting
MAX_CONFESSIONS_PER_DAY=5
MAX_REPLIES_PER_DAY=20

# CORS (Vercel frontend domain)
ALLOWED_ORIGINS=https://your-app-name.vercel.app,https://www.your-domain.com

# Confession Limits
MAX_ACTIVE_CONFESSIONS=2
CONFESSION_EXPIRY_HOURS=24

# Google OAuth (if using)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
