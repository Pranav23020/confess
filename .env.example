# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/confessions

# Redis Configuration (Optional - will use in-memory fallback if not configured)
# For local development (Redis running locally):
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# OR use a full Redis URL (for production/cloud):
# REDIS_URL=redis://username:password@host:port/db
# Examples:
# - Redis Cloud: redis://default:password@redis-12345.c123.us-east-1-1.ec2.cloud.redislabs.com:12345
# - Upstash: redis://default:password@us1-lasting-toucan-12345.upstash.io:6379
# - Local: redis://localhost:6379

# Security
DEVICE_HASH_SECRET=your-secret-key-here-change-in-production
SESSION_SECRET=your-session-secret-here-change-in-production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# Email Configuration (Resend) - REQUIRED for password reset
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM=noreply@anonconfess.in
# Optional fallback if RESEND_FROM is not set
EMAIL_USER=noreply@anonconfess.in

# Frontend URL - Used for password reset links and OAuth redirects
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://your-frontend-domain.com

# Google OAuth Configuration (Optional)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
# Production: GOOGLE_CALLBACK_URL=https://your-api-domain.com/api/auth/google/callback

# Rate Limiting
MAX_CONFESSIONS_PER_DAY=5
MAX_REPLIES_PER_DAY=20

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# Confession Limits
MAX_ACTIVE_CONFESSIONS=2
CONFESSION_EXPIRY_HOURS=24
